# --- Supabase (filled in during Step 2) ---
# Public URL of your Supabase project (looks like https://xxxxx.supabase.co)
EXPO_PUBLIC_SUPABASE_URL=

# Public anon key from Supabase Project Settings -> API
# Safe to expose in client because Row Level Security gates all access.
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Google OAuth (filled in during Step 3) ---
# OAuth client IDs from Google Cloud Console.
# Web client ID is required; iOS/Android only needed for native builds.
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=

# --- App defaults (filled in during Step 6) ---
EXPO_PUBLIC_DEFAULT_CURRENCY=USD
EXPO_PUBLIC_APP_DISPLAY_NAME=Director Accounting
