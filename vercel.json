{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npx expo export --platform web",
  "outputDirectory": "dist",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/contact/:id", "destination": "/contact/[id]" },
    { "source": "/debt/:id", "destination": "/debt/[id]" },
    { "source": "/transaction/:id", "destination": "/transaction/[id]" }
  ]
}
